        return redirect('main:edit_profile')


@login_required
def edit_profile(request):
    try:
        member = request.user.member_profile
    except Member.DoesNotExist:
        member = Member.objects.create(
            user=request.user,
            first_name=request.user.first_name or '',
            last_name=request.user.last_name or '',
            is_active=True
        )

    if request.method == 'POST':
        member.first_name = request.POST.get('first_name', member.first_name)
        member.last_name = request.POST.get('last_name', member.last_name)
        member.middle_initial = request.POST.get('middle_initial', member.middle_initial)
        member.nickname = request.POST.get('nickname', member.nickname)
        member.nationality = request.POST.get('nationality', member.nationality)
        member.contact_number = request.POST.get('contact_number', member.contact_number)
        member.residence_address = request.POST.get('residence_address', member.residence_address)

        birthdate_str = request.POST.get('birthdate')
        if birthdate_str:
            try:
                member.birthdate = datetime.strptime(birthdate_str, '%Y-%m-%d').date()
            except:
                member.birthdate = None

        member.gender = request.POST.get('gender', member.gender)
        member.spouse_name = request.POST.get('spouse_name', member.spouse_name)
        member.num_dependents = int(request.POST.get('num_dependents', 0) or 0)
        member.employer_name = request.POST.get('employer_name', member.employer_name)
        member.position = request.POST.get('position', member.position)
        member.monthly_income = Decimal(request.POST.get('monthly_income', 0) or 0)
        member.farm_location = request.POST.get('farm_location', member.farm_location)
        member.farm_owned_hectares = Decimal(request.POST.get('farm_owned_hectares', 0) or 0)
        member.farm_leased_hectares = Decimal(request.POST.get('farm_leased_hectares', 0) or 0)
        member.area_planted = Decimal(request.POST.get('area_planted', 0) or 0)

        if request.FILES.get('profile_picture'):
            member.profile_picture = request.FILES['profile_picture']

        if request.FILES.get('valid_id'):
            member.uploaded_id = request.FILES['valid_id']

        member.save()

        request.user.first_name = member.first_name
        request.user.last_name = member.last_name
        request.user.save()

        messages.success(request, 'Profile updated successfully!')
        return redirect('main:member_profile')

    context = {
        'member': member,
        'profile_completeness': calculate_profile_completeness(member),
    }
    return render(request, 'main/edit_profile.html', context)


@login_required
def upload_valid_id(request):
    """Upload Valid ID"""
    if request.method == 'POST' and request.FILES.get('valid_id'):
        try:
            member = request.user.member_profile
            member.uploaded_id = request.FILES['valid_id']
            member.save()
            return JsonResponse({'success': True, 'message': 'ID uploaded successfully'})
        except Member.DoesNotExist:
            return JsonResponse({'error': 'Member profile not found'}, status=404)
    return JsonResponse({'error': 'No file uploaded'}, status=400)


