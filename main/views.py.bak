@login_required
def download_receipt(request, payment_id):
    from reportlab.lib.pagesizes import letter
    from reportlab.pdfgen import canvas

    try:
        payment = get_object_or_404(Payment, id=payment_id, member=request.user.member_profile)

        response = HttpResponse(content_type='application/pdf')
        response['Content-Disposition'] = f'attachment; filename="receipt_{payment.payment_number}.pdf"'

        p = canvas.Canvas(response, pagesize=letter)
        width, height = letter

        p.setFont("Helvetica-Bold", 20)
        p.drawString(180, height - 50, "TOMPuCO COOPERATIVE")
        p.setFont("Helvetica-Bold", 14)
        p.drawString(220, height - 80, "OFFICIAL RECEIPT")

        p.setFont("Helvetica", 11)
        y = height - 120
        p.drawString(50, y, f"Receipt Number: {payment.payment_number}")
        p.drawString(50, y - 20, f"Date: {payment.payment_date.strftime('%B %d, %Y')}")
        p.drawString(50, y - 40, f"Member: {payment.member.last_name}, {payment.member.first_name}")
        p.drawString(50, y - 60, f"Loan Number: {payment.loan.loan_number}")

        p.line(50, y - 75, width - 50, y - 75)
        p.drawString(50, y - 95, f"Amount Paid: ₱{payment.amount:,.2f}")
        p.drawString(50, y - 115, f"Payment Method: {payment.get_payment_method_display()}")
        p.drawString(50, y - 135, f"Remaining Balance: ₱{payment.remaining_balance_after:,.2f}")

        p.setFont("Helvetica-Oblique", 10)
        p.drawString(180, 50, "Thank you for your payment!")

        p.save()
        return response
    except Member.DoesNotExist:
        messages.error(request, 'Member profile not found.')
        return redirect('main:edit_profile')


def calculate_profile_completeness(member):
    required_fields = [
        member.first_name, member.last_name, member.contact_number,
        member.residence_address, member.birthdate, member.gender,
        member.monthly_income
    ]
    filled = sum(1 for field in required_fields if field)
    total = len(required_fields)
    return int((filled / total) * 100) if total > 0 else 0


@login_required
def validate_co_maker(request, co_maker_id):
    """Validate co-maker before proceeding"""
    try:
        co_maker = get_object_or_404(Member, id=co_maker_id)

        # Check eligibility
        active_loans_as_comaker = Loan.objects.filter(co_maker=co_maker, status='active').count()
        is_eligible = active_loans_as_comaker < 3

        return JsonResponse({
            'valid': is_eligible,
            'active_loans': active_loans_as_comaker,
            'max_allowed': 3,
            'message': f'This co-maker has {active_loans_as_comaker} active loan(s). Maximum allowed is 3.' if not is_eligible else 'Co-maker is eligible and valid!'
        })
    except Member.DoesNotExist:
        return JsonResponse({'error': 'Co-maker not found'}, status=404)


@login_required
def upload_collateral(request, application_id):
    """Upload collateral documents for an application"""
    if request.method == 'POST' and request.FILES.get('collateral_doc'):
        try:
            application = get_object_or_404(LoanApplication, id=application_id, member=request.user.member_profile)

            collateral_file = request.FILES['collateral_doc']
            file_name = f"collateral_{application.application_id}_{datetime.now().timestamp()}.{collateral_file.name.split('.')[-1]}"
            application.collateral_offered = f"Document uploaded: {file_name}"
            application.save()

            default_storage.save(f'collateral/{file_name}', collateral_file)

            return JsonResponse({'success': True, 'message': 'Collateral document uploaded successfully'})
        except Member.DoesNotExist:
            return JsonResponse({'error': 'Member profile not found'}, status=404)

    return JsonResponse({'error': 'No file uploaded'}, status=400)


@login_required
def chatbot_api(request):
    """FAQ Chatbot API"""
    if request.method == 'POST':
        data = json.loads(request.body)
        question = data.get('message', '').lower()

        faq_responses = {
            'interest rate': 'Our interest rate is 20% per annum for all loan types.',
            'interest': 'Our interest rate is 20% per annum for all loan types.',
            'requirements': 'Loan requirements: Valid ID, Proof of income, Collateral documents, and a valid co-maker.',
            'payment': 'You can pay via cash at our office.',
            'how to apply': 'Go to Apply for Loan page. The form is 95% auto-filled.',
            'status': 'Check your application status in "My Applications" page.',
            'co-maker': 'Co-makers must be active members with less than 3 active loans as co-maker.',
            'otp': 'OTP is sent to verify your identity.',
            'signature': 'Draw your signature on the canvas provided.',
            'documents': 'You need to upload a valid ID and collateral documents.',
            'processing time': 'Loan applications are processed within 3-5 business days.',
        }

        response = "Please contact our support team for assistance."

        for keyword, answer in faq_responses.items():
            if keyword in question:
                response = answer
                break

        return JsonResponse({'response': response})

    return JsonResponse({'error': 'Invalid request'}, status=400)